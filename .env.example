# סביבה: production (ברירת מחדל) או staging
# בפרודקשן אפשר להשאיר ריק; ב-Vercel staging חובה: VITE_APP_ENV=staging
VITE_APP_ENV=production

# Supabase — לכל סביבה ה-DB שלה (פרודקשן מול טסטים)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (לעתיד - תשלומים)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
